{
  "name": "biz-bot",
  "version": "1.0.0",
  "description": "A multi-tenant WhatsApp/web automation platform for SMBs",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "build": "echo 'Build step completed'",
    "test": "jest",
    "lint": "eslint src/",
    "docker:build": "docker build -t biz-bot .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:prod": "docker-compose -f docker-compose.prod.yml up -d",
    "deploy": "chmod +x scripts/deploy.sh && ./scripts/deploy.sh"
  },
  "keywords": [
    "whatsapp",
    "automation",
    "chatbot",
    "multi-tenant",
    "ai",
    "twilio",
    "elevenlabs"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "dotenv": "^16.3.1",
    "twilio": "^4.19.0",
    "openai": "^4.20.0",
    "ioredis": "^5.3.2",
    "pg": "^8.11.3",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.1.5",
    "winston": "^3.11.0",
    "prom-client": "^15.1.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "eslint": "^8.55.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
